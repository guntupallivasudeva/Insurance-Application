# Backend Server Configuration
PORT=8000

# MongoDB Connection
# Local: mongodb://127.0.0.1:27017/insurance_application
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URL=<your_mongodb_connection_string>

# JWT Secret Key
# Use a strong, random string. Example: $(openssl rand -base64 32)
JWT_SECRET=<your_jwt_secret_key>

# Production Frontend URL
# For Vercel: https://your-app-frontend.vercel.app
FRONTEND_URL=<your_frontend_vercel_url>

# Optional: Preview deployment URL
FRONTEND_PREVIEW_URL=<optional_preview_url>

# DO NOT COMMIT THIS FILE WITH REAL SECRETS
# This file is gitignored. Copy this template and fill with actual values.
